# Server Configurations
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Connections
MONGO_URI=mongodb://127.0.0.1:27017/placemate

# Authentication
JWT_SECRET=replace_this_with_a_secure_random_string_in_production
JWT_EXPIRE=7d

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP/OAuth2 Settings
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_CLIENT_ID=your_oauth2_client_id
GMAIL_CLIENT_SECRET=your_oauth2_client_secret
GMAIL_REFRESH_TOKEN=your_oauth2_refresh_token

# RapidAPI JSearch API Credentials
RAPIDAPI_KEY=your_rapidapi_key_here
